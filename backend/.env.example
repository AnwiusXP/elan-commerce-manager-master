# ============================================================
# ECM — Backend / Variables de Entorno (Plantilla para local)
# ============================================================
# COPIA este archivo como .env y ajusta los valores locales.
# .env está en .gitignore, NUNCA se sube a Git.
# ============================================================

# --- Base de Datos ---
# Prioridad 1: DATABASE_URL (Render inyecta esta variable en producción)
# Si existe, se usa siempre (PostgreSQL).
# Prioridad 2: Si NO existe y ENVIRONMENT=development o LOCAL_DB=sqlite,
# se usa SQLite local (sin necesidad de PostgreSQL instalado).
# Prioridad 3: LOCAL_DATABASE_URL (PostgreSQL local).

# Para PostgreSQL local (opción por defecto):
# DATABASE_URL=postgresql://postgres:1234@localhost:5432/elan_db

# Para SQLite local (alternativa ligera — descomenta ambas líneas):
# ENVIRONMENT=development
# LOCAL_DB=sqlite

# Para PostgreSQL local con URL explícita (alternativa):
# LOCAL_DATABASE_URL=postgresql://user_elan:password_elan@localhost:5432/elan_db

# --- Frontend ---
# URL del frontend (usada para CORS y enlaces en correos)
FRONTEND_URL=http://localhost:5173

# --- Orígenes CORS Extra ---
# Lista separada por comas para IPs locales, Ngrok, etc.
# EXTRA_ORIGINS=http://192.168.1.10:5173,https://xxxx.ngrok.io

# --- Google Gemini AI ---
# Clave API del microservicio de IA (modelo usado: gemini-3.1-flash-lite)
GOOGLE_API_KEY=

# --- Correo (SMTP) ---
# Para desarrollo local se recomienda MailHog (localhost:1025, sin SSL)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_STARTTLS=false
MAIL_SSL_TLS=false
FROM_EMAIL=noreply@elan.com
SMTP_USER=
SMTP_PASSWORD=
